# Sao chép file này thành `secrets.toml` trong cùng thư mục `.streamlit/`
# (file `secrets.toml` đã được .gitignore — không đẩy lên git).
#
# Mật khẩu đăng nhập admin cho ứng dụng Streamlit:

ADMIN_PASSWORD = "đặt-mật-khẩu-của-bạn-tại-đây"

# WebRTC camera (tùy chọn): app đọc từ biến môi trường OS — không đọc tự động từ secrets.toml.
# Trên VPS nên đặt trong systemd EnvironmentFile=... hoặc export trước khi chạy streamlit:
#   TURN_URI="turn:relay.example.com:3478"
#   TURN_USERNAME="..."
#   TURN_PASSWORD="..."
# Hoặc JSON mở rộng: WEBRTC_ICE_SERVERS_JSON='[{"urls":"stun:..."}]'
#
# Camera WebRTC — preset (biến môi trường OS, restart Streamlit): WEBCAM_QUALITY_PRESET=fast|balanced|sharp
# WEBCAM_JPEG_QUALITY=92 (70–100) cho ảnh đăng ký lưu đĩa.
